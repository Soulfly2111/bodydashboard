generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  username     String?        @unique
  email        String         @unique
  name         String
  firstName    String?
  lastName     String?
  avatarUrl    String?
  passwordHash String
  language     String         @default("de")
  units        String         @default("metric")
  theme        String         @default("system")
  timezone     String         @default("Europe/Berlin")
  role         String         @default("USER")
  status       String         @default("ACTIVE")
  failedLoginAttempts Int     @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  heightCm     Float?
  trackWeight  Boolean        @default(true)
  trackBodyFat Boolean        @default(true)
  trackMuscleMass Boolean     @default(true)
  trackWater   Boolean        @default(true)
  visiblePagesJson String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  foods        Food[]
  meals        Meal[]
  recipes      Recipe[]
  weights      WeightEntry[]
  waters       WaterEntry[]
  goal         Goal?
  favorites    Favorite[]
  imports      ImportSource[]
  aiSettings   AiRecognitionSetting?
  aiAnalyses   AiMealAnalysis[]
  sessions     UserSession[]
  passwordResetTokens PasswordResetToken[]
  auditLogs     AuditLog[]
  integrationApiKeys IntegrationApiKey[]

  @@index([role])
  @@index([status])
}

model IntegrationApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  provider    String    @default("openclaw")
  keyHash     String    @unique
  keyPrefix   String
  keyLast4    String
  scopesJson  String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([provider])
  @@index([keyPrefix])
}

model Food {
  id              String       @id @default(cuid())
  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  brand           String?
  category        String?
  barcode         String?
  caloriesPer100g Float
  protein         Float
  fat             Float
  carbs           Float
  sugar           Float        @default(0)
  fiber           Float        @default(0)
  salt            Float        @default(0)
  source          String       @default("manual")
  externalId      String?
  importedAt      DateTime?
  lastSyncedAt    DateTime?
  sourcePayload   String?
  isPublic        Boolean      @default(false)
  lastUsedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  mealItems       MealItem[]
  recipeItems     RecipeItem[]

  @@unique([userId, externalId, source])
  @@index([name])
  @@index([barcode])
}

model Meal {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  type      String
  name      String?
  items     MealItem[]
  aiAnalyses AiMealAnalysis[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, date, type])
  @@index([userId, date])
}

model MealItem {
  id          String   @id @default(cuid())
  mealId      String
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  foodId      String
  food        Food     @relation(fields: [foodId], references: [id])
  amount      Float
  unit        String   @default("g")
  servingName String?
  createdAt   DateTime @default(now())
}

model Recipe {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  servings     Int          @default(1)
  instructions String?
  category     String?
  source       String       @default("manual")
  externalId   String?
  items        RecipeItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, externalId, source])
}

model RecipeItem {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodId   String
  food     Food   @relation(fields: [foodId], references: [id])
  amount   Float
  unit     String @default("g")
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  weightKg  Float?
  bodyFatPercent Float?
  muscleMassKg Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  amountMl  Int
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calories  Int      @default(2200)
  protein   Int      @default(150)
  fat       Int      @default(70)
  carbs     Int      @default(250)
  waterMl   Int      @default(2500)
  weightKg  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  targetId  String
  label     String
  createdAt DateTime @default(now())

  @@unique([userId, type, targetId])
}

model ImportSource {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  name              String
  baseUrl           String
  spaceKey          String?
  pageId            String?
  pageTitle         String?
  encryptedUsername String?
  encryptedApiToken String
  authType          String
  mappingJson       String
  syncMode          String      @default("UPSERT")
  autoImportCron    String?
  lastImportedAt    DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  logs              ImportLog[]
}

model ImportLog {
  id            String       @id @default(cuid())
  sourceId      String
  source        ImportSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  recordType    String
  status        String
  message       String
  importedCount Int          @default(0)
  updatedCount  Int          @default(0)
  skippedCount  Int          @default(0)
  conflictCount Int          @default(0)
  payloadJson   String?
  createdAt     DateTime     @default(now())
}

model AiRecognitionSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode                String   @default("REVIEW_REQUIRED")
  minConfidence       Int      @default(90)
  storeImages         Boolean  @default(false)
  deleteAfterAnalysis Boolean  @default(true)
  linkImageToMeal     Boolean  @default(false)
  provider            String   @default("local")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AiMealAnalysis {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealId            String?
  meal              Meal?                @relation(fields: [mealId], references: [id], onDelete: SetNull)
  date              DateTime
  mealType          String
  customMealTag     String?
  provider          String
  status            String               @default("DRAFT")
  mode              String               @default("REVIEW_REQUIRED")
  confidence        Int                  @default(0)
  imagePath         String?
  imageFileName     String?
  imageMimeType     String?
  imageSha256       String?
  rawResultJson     String?
  manualChangesJson String?
  totalsJson        String?
  analyzedAt        DateTime             @default(now())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  items             AiMealAnalysisItem[]

  @@index([userId, date])
  @@index([userId, status])
}

model AiMealAnalysisItem {
  id            String         @id @default(cuid())
  analysisId    String
  analysis      AiMealAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  foodId        String?
  name          String
  category      String?
  amount        Float
  weightGrams   Float
  servingName   String?
  calories      Float
  protein       Float
  carbs         Float
  fat           Float
  fiber         Float          @default(0)
  sugar         Float          @default(0)
  salt          Float          @default(0)
  confidence    Int
  source        String         @default("ai_estimate")
  thumbnailPath String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique
  userAgent        String?
  ipAddress        String?
  rememberMe       Boolean  @default(false)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadataJson String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([actorUserId])
  @@index([action])
}
