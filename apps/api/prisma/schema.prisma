generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  username     String?        @unique
  email        String         @unique
  name         String
  firstName    String?
  lastName     String?
  avatarUrl    String?
  passwordHash String
  language     String         @default("de")
  units        String         @default("metric")
  theme        String         @default("system")
  timezone     String         @default("Europe/Berlin")
  role         String         @default("USER")
  status       String         @default("ACTIVE")
  failedLoginAttempts Int     @default(0)
  lockedUntil  DateTime?
  lastLoginAt  DateTime?
  heightCm     Float?
  trackWeight  Boolean        @default(true)
  trackBodyFat Boolean        @default(true)
  trackMuscleMass Boolean     @default(true)
  trackWater   Boolean        @default(true)
  visiblePagesJson String?
  dashboardWidgetsJson String?
  dashboardMetricCardsJson String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  foods        Food[]
  meals        Meal[]
  recipes      Recipe[]
  weights      WeightEntry[]
  waters       WaterEntry[]
  activities   Activity[]
  bodyPhotos   BodyPhoto[]
  bodyMeasurements BodyMeasurement[]
  bodyProgressSettings BodyProgressSettings?
  goal         Goal?
  activityGoal ActivityGoal?
  favorites    Favorite[]
  imports      ImportSource[]
  aiSettings   AiRecognitionSetting?
  aiAnalyses   AiMealAnalysis[]
  sessions     UserSession[]
  passwordResetTokens PasswordResetToken[]
  auditLogs     AuditLog[]
  integrationApiKeys IntegrationApiKey[]

  @@index([role])
  @@index([status])
}

model IntegrationApiKey {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  provider    String    @default("openclaw")
  keyHash     String    @unique
  keyPrefix   String
  keyLast4    String
  scopesJson  String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([provider])
  @@index([keyPrefix])
}

model Food {
  id              String       @id @default(cuid())
  userId          String?
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  brand           String?
  category        String?
  barcode         String?
  caloriesPer100g Float
  protein         Float
  fat             Float
  carbs           Float
  sugar           Float        @default(0)
  fiber           Float        @default(0)
  salt            Float        @default(0)
  source          String       @default("manual")
  externalId      String?
  importedAt      DateTime?
  lastSyncedAt    DateTime?
  sourcePayload   String?
  isPublic        Boolean      @default(false)
  lastUsedAt      DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  mealItems       MealItem[]
  recipeItems     RecipeItem[]

  @@unique([userId, externalId, source])
  @@index([name])
  @@index([barcode])
}

model Meal {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  type      String
  name      String?
  items     MealItem[]
  aiAnalyses AiMealAnalysis[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([userId, date, type])
  @@index([userId, date])
}

model MealItem {
  id          String   @id @default(cuid())
  mealId      String
  meal        Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  foodId      String
  food        Food     @relation(fields: [foodId], references: [id])
  amount      Float
  unit        String   @default("g")
  servingName String?
  createdAt   DateTime @default(now())
}

model Recipe {
  id           String       @id @default(cuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  servings     Int          @default(1)
  instructions String?
  category     String?
  source       String       @default("manual")
  externalId   String?
  items        RecipeItem[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([userId, externalId, source])
}

model RecipeItem {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodId   String
  food     Food   @relation(fields: [foodId], references: [id])
  amount   Float
  unit     String @default("g")
}

model WeightEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  weightKg  Float?
  bodyFatPercent Float?
  muscleMassKg Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
}

model WaterEntry {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime
  amountMl  Int
  createdAt DateTime @default(now())

  @@index([userId, date])
}

model Goal {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  calories  Int      @default(2200)
  protein   Int      @default(150)
  fat       Int      @default(70)
  carbs     Int      @default(250)
  waterMl   Int      @default(2500)
  weightKg  Float?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityType {
  id          String     @id @default(cuid())
  slug        String     @unique
  name        String
  category    String
  defaultMet  Float
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  metValues   METValue[]
  activities  Activity[]

  @@index([category])
}

model METValue {
  id             String       @id @default(cuid())
  activityTypeId String
  activityType   ActivityType @relation(fields: [activityTypeId], references: [id], onDelete: Cascade)
  intensity      String
  met            Float
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([activityTypeId, intensity])
}

model Activity {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activityTypeId  String?
  activityType    ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)
  typeName        String
  date            DateTime
  startTime       String?
  endTime         String?
  durationMinutes Int
  intensity       String        @default("MEDIUM")
  distanceKm      Float?
  averageSpeedKmh Float?
  averageHeartRate Int?
  maxHeartRate    Int?
  calories        Float
  caloriesOverride Boolean      @default(false)
  notes           String?
  steps           Int?
  elevationGainM  Float?
  powerWatts      Float?
  cadence         Float?
  pace            String?
  source          String        @default("manual")
  externalId      String?
  muscleGroupsJson String?
  exercisesCount  Int?
  setsCount       Int?
  repsCount       Int?
  trainingVolume  Float?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  workout         Workout?

  @@index([userId, date])
  @@index([activityTypeId])
  @@index([source, externalId])
}

model ActivityGoal {
  id                      String   @id @default(cuid())
  userId                  String   @unique
  user                    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trainingDaysPerWeek     Int      @default(3)
  trainingMinutesPerWeek  Int      @default(180)
  caloriesPerWeek         Int      @default(1500)
  stepsPerDay             Int      @default(8000)
  strengthSessionsPerWeek Int      @default(2)
  cardioSessionsPerWeek   Int      @default(2)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Workout {
  id          String            @id @default(cuid())
  userId      String
  activityId  String?           @unique
  activity    Activity?         @relation(fields: [activityId], references: [id], onDelete: Cascade)
  name        String
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  exercises   WorkoutExercise[]

  @@index([userId])
}

model WorkoutExercise {
  id          String       @id @default(cuid())
  workoutId   String
  workout     Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  name        String
  muscleGroup String?
  order       Int          @default(0)
  sets        WorkoutSet[]
}

model WorkoutSet {
  id         String          @id @default(cuid())
  exerciseId String
  exercise   WorkoutExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  reps       Int?
  weightKg   Float?
  durationSeconds Int?
  distanceMeters Float?
  order      Int             @default(0)
}

model BodyMeasurementType {
  id          String            @id @default(cuid())
  slug        String            @unique
  name        String
  unit        String            @default("cm")
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  measurements BodyMeasurement[]
}

model BodyPhoto {
  id                  String              @id @default(cuid())
  userId              String
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                DateTime
  viewType            String
  imageUrl            String
  thumbnailUrl        String?
  notes               String?
  linkedWeightEntryId String?
  trainingPhase       String?
  dietPhase           String?
  referenceObject     String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  analyses            BodyPhotoAnalysis[]

  @@index([userId, date])
  @@index([viewType])
}

model BodyMeasurement {
  id                  String               @id @default(cuid())
  userId              String
  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                DateTime
  measurementTypeId   String?
  measurementTypeRef  BodyMeasurementType? @relation(fields: [measurementTypeId], references: [id], onDelete: SetNull)
  measurementType     String
  value               Float
  unit                String               @default("cm")
  source              String               @default("manual")
  confidence          Int?
  confirmedByUser     Boolean              @default(true)
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([userId, date])
  @@index([measurementType])
}

model BodyPhotoAnalysis {
  id                        String    @id @default(cuid())
  photoId                   String
  photo                     BodyPhoto @relation(fields: [photoId], references: [id], onDelete: Cascade)
  provider                  String
  detectedViewType          String?
  imageQualityScore         Int?
  estimatedMeasurementsJson String?
  confidenceJson            String?
  analysisText              String
  warnings                  String?
  createdAt                 DateTime  @default(now())

  @@index([photoId])
}

model BodyProgressComparison {
  id             String   @id @default(cuid())
  userId         String
  fromDate       DateTime
  toDate         DateTime
  summaryJson    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, fromDate, toDate])
}

model BodyProgressSettings {
  id                         String   @id @default(cuid())
  userId                     String   @unique
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiMode                     String   @default("SHOW_ONLY")
  minConfidenceForAutoApply  Int      @default(90)
  useHeightAsReference       Boolean  @default(true)
  localStorageOnly           Boolean  @default(true)
  encryptedStorage           Boolean  @default(false)
  deletePhotosAfterAnalysis  Boolean  @default(false)
  maxImageSizeMb             Int      @default(8)
  stripExif                  Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  targetId  String
  label     String
  createdAt DateTime @default(now())

  @@unique([userId, type, targetId])
}

model ImportSource {
  id                String      @id @default(cuid())
  userId            String
  user              User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  name              String
  baseUrl           String
  spaceKey          String?
  pageId            String?
  pageTitle         String?
  encryptedUsername String?
  encryptedApiToken String
  authType          String
  mappingJson       String
  syncMode          String      @default("UPSERT")
  autoImportCron    String?
  lastImportedAt    DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  logs              ImportLog[]
}

model ImportLog {
  id            String       @id @default(cuid())
  sourceId      String
  source        ImportSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  recordType    String
  status        String
  message       String
  importedCount Int          @default(0)
  updatedCount  Int          @default(0)
  skippedCount  Int          @default(0)
  conflictCount Int          @default(0)
  payloadJson   String?
  createdAt     DateTime     @default(now())
}

model AiRecognitionSetting {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mode                String   @default("REVIEW_REQUIRED")
  minConfidence       Int      @default(90)
  storeImages         Boolean  @default(false)
  deleteAfterAnalysis Boolean  @default(true)
  linkImageToMeal     Boolean  @default(false)
  provider            String   @default("local")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AiMealAnalysis {
  id                String               @id @default(cuid())
  userId            String
  user              User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  mealId            String?
  meal              Meal?                @relation(fields: [mealId], references: [id], onDelete: SetNull)
  date              DateTime
  mealType          String
  customMealTag     String?
  provider          String
  status            String               @default("DRAFT")
  mode              String               @default("REVIEW_REQUIRED")
  confidence        Int                  @default(0)
  imagePath         String?
  imageFileName     String?
  imageMimeType     String?
  imageSha256       String?
  rawResultJson     String?
  manualChangesJson String?
  totalsJson        String?
  analyzedAt        DateTime             @default(now())
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  items             AiMealAnalysisItem[]

  @@index([userId, date])
  @@index([userId, status])
}

model AiMealAnalysisItem {
  id            String         @id @default(cuid())
  analysisId    String
  analysis      AiMealAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  foodId        String?
  name          String
  category      String?
  amount        Float
  weightGrams   Float
  servingName   String?
  calories      Float
  protein       Float
  carbs         Float
  fat           Float
  fiber         Float          @default(0)
  sugar         Float          @default(0)
  salt          Float          @default(0)
  confidence    Int
  source        String         @default("ai_estimate")
  thumbnailPath String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokenHash String   @unique
  userAgent        String?
  ipAddress        String?
  rememberMe       Boolean  @default(false)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  actorUserId String?
  action      String
  entityType  String?
  entityId    String?
  ipAddress   String?
  userAgent   String?
  metadataJson String?
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([actorUserId])
  @@index([action])
}
